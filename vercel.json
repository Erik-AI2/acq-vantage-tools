{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/*.ts": {
      "maxDuration": 60,
      "includeFiles": "server/prompts/**"
    }
  },
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/audit", "destination": "/api/audit" },
    { "source": "/api/health", "destination": "/api/health" }
  ]
}
